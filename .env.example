# UAE Roots Family Tree Application - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED: Authentication & Security
# ===========================================

# JWT secret for token signing (minimum 32 characters in production)
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# Encryption key for PII at rest (must be different from JWT_SECRET)
# If not set, falls back to JWT_SECRET (not recommended for production)
ENCRYPTION_KEY=your-encryption-key-different-from-jwt-secret

# ===========================================
# REQUIRED: Database
# ===========================================

# PostgreSQL connection URL
DATABASE_URL=postgresql://user:password@host:5432/database

# ===========================================
# REQUIRED: Firebase Authentication
# ===========================================

# Firebase project configuration (client-side)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ===========================================
# REQUIRED: Twilio SMS Verification
# ===========================================

# Twilio Verify Service SID for SMS OTP
TWILIO_VERIFY_SID=VA...

# ===========================================
# OPTIONAL: Production Configuration
# ===========================================

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Set to 'production' for production deployments
# NODE_ENV=production
